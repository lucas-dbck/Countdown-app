# Flask backend
SECRET_KEY=replace-this-with-a-long-random-secret
SESSION_COOKIE_SECURE=true

# Optional when the frontend calls Flask directly from another domain.
# If you use the Vercel rewrite described in DEPLOYMENT.md, Vercel uses FLASK_API_URL instead.
FRONTEND_ORIGINS=https://your-vercel-app.vercel.app

# Vercel frontend
FLASK_API_URL=https://your-pythonanywhere-username.pythonanywhere.com
